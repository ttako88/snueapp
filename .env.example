# ============================================================
# 환경변수 목록 (이름과 설명만 — 실제 값은 절대 이 파일에 넣지 않음)
#
# 실제 값 위치:
#  - 로컬 개발:   .env.local        (git에 안 올라감 — .gitignore의 .env* 패턴)
#  - dev 값 보관: .env.dev.local    (git에 안 올라감)
#  - 배포(운영):  Vercel 대시보드 → Settings → Environment Variables
#
# dev ↔ 운영 전환 절차: docs/OPERATIONS.md 참고
# ============================================================

# Supabase 프로젝트 URL (예: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable 키 (sb_publishable_... — 브라우저 공개 가능, 보안은 RLS가 담당)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ⚠️ secret 키(sb_secret_...)는 어떤 NEXT_PUBLIC_ 변수에도 절대 넣지 않는다.
#    NEXT_PUBLIC_ 접두사가 붙으면 클라이언트 번들에 실려 브라우저로 나간다.

# ------------------------------------------------------------
# 학생 인증 파이프라인 (서버 전용 — Vercel 은 "Sensitive" 체크)
#
#   아래 셋은 직접 편집하지 말고 이 명령으로 등록하는 편이 안전하다.
#   값 검증까지 해 주고, 화면에 값을 찍지 않는다:
#
#     node scripts/manual/setup-verify-secret.mjs
#
#   등록 후 확인:
#     node scripts/manual/diag-verification-ready.mjs   준비 상태
#     node scripts/manual/verify-e2e-smoke.mjs          실제 제출 흐름
# ------------------------------------------------------------

# Supabase secret 키 (sb_secret_...). 없으면 /api/verification/* 가 전부 503.
SUPABASE_SECRET_KEY=

# 학번 HMAC 키. 32자 이상 무작위. 로컬과 운영은 서로 **다른 값**을 쓴다.
# ⚠️ 잃으면 복구 불가 — 학번 원문을 저장하지 않아 재계산할 방법이 없고,
#    그 버전으로 저장된 해시의 중복가입 차단이 영구히 사라진다.
VERIFY_HMAC_KEY_V1=

# 신규 저장에 쓸 키 버전. 키를 교체해도 과거 버전 키는 지우지 않는다
# (중복 대조를 보존 중인 전 버전으로 각각 계산하기 때문).
VERIFY_HMAC_CURRENT_VER=

# Vercel Cron 인증용 (배치 활성화 시). 16자 이상.
CRON_SECRET=
