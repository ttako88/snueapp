# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 단, 변수 목록 문서(값 없음)는 커밋한다
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 개인 자료 (실명·학번 등 포함, 공개 저장소에 올리지 않음)
학교문의_이메일초안.md

# 운영 DB 백업 산출물
# 이메일·닉네임·글 본문·auth user id 등 실제 개인정보가 들어간다.
# 공개 저장소에 절대 올라가면 안 되므로 디렉터리째 제외한다.
# (백업을 만들기 전에 이 규칙이 먼저 있어야 한다 — 사고는 순서를 안 봐준다)
/backups/
*.dump
*.pgdump
--dump
